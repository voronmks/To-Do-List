const tasks = [];

function addTask(task) {
    tasks.push(task);
}

function showTasks() {
    console.log("To-Do List:");
    tasks.forEach((task, index) => {
        console.log(`${index + 1}. ${task}`);
    });
}

addTask("Learn JavaScript");
addTask("Build a project");
addTask("Push to GitHub");

showTasks();
